# --- VPS SSH connection (single host) ---

# Required: VPS hostname or IP
SSH_HOST=

# Port (default 22)
SSH_PORT=22

# Required: SSH user (e.g. root, ubuntu)
SSH_USERNAME=

# Auth method: "privateKey" (recommended) or "password"
SSH_AUTH_METHOD=privateKey

# Required when SSH_AUTH_METHOD=password
SSH_PASSWORD=

# Required when SSH_AUTH_METHOD=privateKey
# Path to your private key. "~" is expanded to your home dir.
SSH_PRIVATE_KEY_PATH=~/.ssh/id_ed25519

# Optional: passphrase for an encrypted private key
SSH_PASSPHRASE=

# Optional: default per-command timeout in milliseconds (default 120000 = 2 min)
SSH_EXEC_TIMEOUT_MS=120000
